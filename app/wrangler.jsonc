{
  "name": "sigillo-app",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/index.js",
  "rules": [
    { "type": "Text", "globs": ["**/*.sql"], "fallthrough": true }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "SECRETS_STORE", "class_name": "SecretsStore" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SecretsStore"] }
  ],
  // Create KV with: wrangler kv namespace create CONFIG_KV
  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "placeholder-create-with-wrangler-kv-namespace-create" }
  ],
  "vars": {
    "PROVIDER_URL": "https://auth.sigillo.dev"
  },
  "secrets": {
    "required": ["BETTER_AUTH_SECRET", "ENCRYPTION_KEY"]
  },
  "env": {
    "preview": {
      "name": "sigillo-app-preview",
      "durable_objects": {
        "bindings": [
          { "name": "SECRETS_STORE", "class_name": "SecretsStore" }
        ]
      },
      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["SecretsStore"] }
      ],
      // Create KV with: wrangler kv namespace create CONFIG_KV --env preview
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "placeholder-preview" }
      ],
      "vars": {
        "PROVIDER_URL": "https://auth.preview.sigillo.dev"
      },
      "secrets": {
        "required": ["BETTER_AUTH_SECRET", "ENCRYPTION_KEY"]
      }
    }
  }
}
