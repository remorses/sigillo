{
  "name": "db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Drizzle schemas and migrations for sigillo Durable Object databases",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./src/*.ts": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate:provider": "drizzle-kit generate --config drizzle.provider.config.ts",
    "db:generate:app": "drizzle-kit generate --config drizzle.app.config.ts"
  },
  "devDependencies": {
    "drizzle-kit": "1.0.0-beta.21",
    "drizzle-orm": "1.0.0-beta.21",
    "typescript": "^6.0.2",
    "ulid": "^3.0.2"
  }
}
