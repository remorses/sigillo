{
  "name": "sigillo",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter sigillo-app build",
    "deploy": "wrangler d1 migrations apply DB --remote --config app/wrangler.jsonc && wrangler deploy --config app/wrangler.jsonc"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "spiceflow": "1.26.0-rsc.0"
    }
  }
}
